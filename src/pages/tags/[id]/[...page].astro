---
import type { GetStaticPathsOptions, Page } from 'astro';
import { type CollectionEntry } from 'astro:content';
import Pagination from '../../../components/Pagination.astro';
import PostPreview from '../../../components/PostPreview.astro';
import ProjectPreview from '../../../components/ProjectPreview.astro';
import Subscribe from '../../../components/Subscribe.astro';
import siteConfig from '../../../data/site-config';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getAllPosts } from '../../../utils/content-utils';
import { getAllTags, getPostsByTag } from '../../../utils/data-utils';
import { sortPostsByTitlePinyin } from '../../../utils/sort-by-pinyin';

const posts = await getAllPosts();

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
    const posts = await getAllPosts();
    const tags = getAllTags(posts);

    return tags.flatMap((tag) => {
        const filteredPosts = getPostsByTag(posts, tag.id);
        // blog 和 projects 从不共用标签，同一个标签页下的内容永远只属于一种 collection：
        // projects 是百科条目，按标题拼音排序；blog 保留 getAllPosts() 已经排好的日期倒序。
        // 在分页之前排序，确保每一页内部顺序连续，而不是分页后再零散地重排当页内容。
        const sortedPosts = filteredPosts[0]?.collection === 'projects' ? sortPostsByTitlePinyin(filteredPosts) : filteredPosts;
        return paginate(sortedPosts, {
            params: { id: tag.id },
            pageSize: siteConfig.postsPerPage || 4
        });
    });
}

type Props = { page: Page<CollectionEntry<'blog'> | CollectionEntry<'projects'>> };

const { page } = Astro.props;
const blogPosts = page.data.filter((item): item is CollectionEntry<'blog'> => item.collection === 'blog');
const projectPosts = page.data.filter((item): item is CollectionEntry<'projects'> => item.collection === 'projects');
const params = Astro.params;
const allTags = getAllTags(posts);
const currentTag = allTags.find((tag) => {
    return tag.id === params.id;
});
---

<BaseLayout
    title={`${currentTag?.name}`}
    description={`Explore a curated collection of blog posts under ${currentTag?.name}`}
    image={{ src: '/title.png', alt: 'The preview of the site' }}
    showHeader={false}
>
    <h1 class="mb-12 text-2xl leading-tight font-serif italic sm:mb-16 sm:text-4xl">"{currentTag?.name}"</h1>
    {blogPosts.map((post) => <PostPreview post={post} class="mb-10 sm:mb-12" />)}
    {projectPosts.map((project) => <ProjectPreview project={project} class="mb-10 sm:mb-12" />)}
    <Pagination page={page} basePath={`/tags/${params.id}`} class="my-16 sm:my-24" />
    <Subscribe class="my-16 sm:my-24" />
</BaseLayout>

<script is:inline define:vars={{ tagId: params.id }}>
    // 记录用户是从哪个 tag 列表页进来的，供详情页面包屑组件读取，
    // 拼出「分类：XX」/「音序：X」这一级。见 Breadcrumb.astro。
    function recordBreadcrumbContext() {
        try {
            const type = tagId.startsWith('wiki-') ? 'pinyin' : 'category';
            sessionStorage.setItem('wiki-breadcrumb-context', JSON.stringify({ type, value: tagId }));
        } catch {
            // sessionStorage 不可用（如隐私模式）时静默跳过
        }
    }

    recordBreadcrumbContext();
    document.addEventListener('astro:page-load', recordBreadcrumbContext);
</script>
