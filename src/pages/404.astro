---
import Button from '../components/Button.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到" description="你访问的页面不存在，或者已经被移动到别的地方。" showHeader={false}>
    <div class="flex flex-col items-center py-24 text-center">
        <h1 class="mb-6 text-2xl leading-tight font-serif italic sm:text-4xl">页面未找到</h1>
        <p class="mb-10 text-sm leading-normal sm:text-base">你访问的页面不存在，或者已经被移动到别的地方。</p>
        <Button href="/">返回首页</Button>
    </div>
</BaseLayout>
