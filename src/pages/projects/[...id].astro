---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import ProjectPreview from '../../components/ProjectPreview.astro';
import WalineComments from '../../components/WalineComments.tsx';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortPostsByTitlePinyin } from '../../utils/sort-by-pinyin';

export async function getStaticPaths() {
    // projects 是百科条目，不讲究发布时间，按标题拼音排序而非日期。
    // 上一篇/下一篇限定在同一个分类标签（非 wiki-X 拼音标签）内，
    // 避免人物、装备、关卡等不同类型的词条按全局拼音顺序随机穿插到彼此中间。
    const projects = await getCollection('projects');

    const groups = new Map<string, CollectionEntry<'projects'>[]>();
    for (const project of projects) {
        const category = project.data.tags.find((tag) => !tag.startsWith('wiki-')) ?? project.id;
        const group = groups.get(category) ?? [];
        group.push(project);
        groups.set(category, group);
    }

    return [...groups.values()].flatMap((group) => {
        const sorted = sortPostsByTitlePinyin(group);
        const groupCount = sorted.length;
        return sorted.map((project, index) => ({
            params: { id: project.id },
            props: {
                project,
                prevProject: index + 1 !== groupCount ? sorted[index + 1] : null,
                nextProject: index !== 0 ? sorted[index - 1] : null
            }
        }));
    });
}

type Props = {
    project: CollectionEntry<'projects'>;
    prevProject: CollectionEntry<'projects'>;
    nextProject: CollectionEntry<'projects'>;
};

const { project, prevProject, nextProject } = Astro.props;
const { title, description, seo } = project.data;
const { Content } = await render(project);
---

<BaseLayout title={seo?.title ?? title} description={seo?.description ?? description} image={seo?.image} pageType="article" showHeader={false}>
    <article class="mb-16 sm:mb-24">
        <header class="mb-8">
            <h1 class="text-3xl leading-tight font-serif font-medium sm:text-5xl sm:leading-tight">{title}</h1>
        </header>
        <div class="max-w-none prose sm:prose-lg font-serif wiki">
            <Content />
        </div>
    </article>
    {
        (prevProject || nextProject) && (
            <div class="my-4 flex justify-between">
                {prevProject && (
                    <div>
                        <h2 class="mb-12 text-xl font-serif italic sm:mb-10 sm:text-2xl">←上一篇</h2>{' '}
                        <ProjectPreview project={prevProject} class="mb-10 sm:mb-12" headingLevel="h3" />
                    </div>
                )}
                {nextProject && (
                    <div>
                        <h2 class="mb-12 text-xl font-serif italic sm:mb-10 sm:text-2xl text-right">下一篇→</h2>{' '}
                        <ProjectPreview project={nextProject} class="mb-10 sm:mb-12 text-right" headingLevel="h3" />
                    </div>
                )}
            </div>
        )
    }
    <WalineComments client:load />
</BaseLayout>
