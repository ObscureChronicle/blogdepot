---
// props: name, baseData, dlcData, traitsBase, traitsDLC, biography, battlesBase, battlesDLC, equipments, links

type TraitWikiProps = {
    intro?: string;
    level?: number;
    baseEnable?: number;
    dlcEnable?: number;
    baseData?: boolean;
    dlcData?: boolean;
    owner: string[];
    description: string;
    effect: string;
};

const { intro, level, baseEnable, dlcEnable, baseData, dlcData, owner, description, effect } = Astro.props as TraitWikiProps;

import TraitDescription from './TraitDescription.astro';
import TraitEffect from './TraitEffect.astro';
import TraitIntro from './TraitIntro.astro';
import TraitOwner from './TraitOwner.astro';
---

<TraitIntro baseData={baseData} dlcData={dlcData} level={level} />
<TraitOwner owner={owner} />
<TraitDescription description={description} />
<TraitEffect effect={effect} />
