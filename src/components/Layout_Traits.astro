---
type TraitWikiProps = {
    intro?: string;
    introHtml?: string;
    level?: number;
    baseEnable?: number;
    dlcEnable?: number;
    baseData?: boolean;
    dlcData?: boolean;
    baseOwner?: string[];
    dlcOwner?: string[];
    baseDescription?: string;
    dlcDescription?: string;
    effect?: string;
    noteHtml?: string;
};

const { intro, introHtml, level, baseEnable, dlcEnable, baseData, dlcData, baseOwner, dlcOwner, baseDescription, dlcDescription, effect, noteHtml } =
    Astro.props as TraitWikiProps;

import TraitDescription from './TraitDescription.astro';
import TraitEffect from './TraitEffect.astro';
import TraitIntro from './TraitIntro.astro';
import TraitNote from './TraitNote.astro';
import TraitOwner from './TraitOwner.astro';

const hasBase = (baseOwner && baseOwner.length > 0) || (baseDescription && baseDescription.length > 0);
const hasDlc = (dlcOwner && dlcOwner.length > 0) || (dlcDescription && dlcDescription.length > 0);
---

<TraitIntro baseData={introHtml ? true : hasBase || undefined} dlcData={introHtml ? true : hasDlc || undefined} level={level} introHtml={introHtml} />
<TraitOwner baseOwner={baseOwner || []} dlcOwner={dlcOwner || []} />
<TraitDescription baseDescription={baseDescription || ''} dlcDescription={dlcDescription || ''} />
<TraitEffect effect={effect || ''} />
<TraitNote noteHtml={noteHtml} />
