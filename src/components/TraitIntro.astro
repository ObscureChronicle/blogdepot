---
type Props = {
    baseData?: boolean;
    dlcData?: boolean;
    level?: number;
};

const { baseData, dlcData, level } = Astro.props as Props;

const basename = '《后汉稽异录》';
const dlcname = '《后汉稽异录外传：星命诀》';
---

{
    !baseData && !dlcData ? (
        <div>背景人物。</div>
    ) : (
        <>
            <h2 class="bg-blue-100 text-blue-800 text-2xl font-bold px-2.5 pt-1.5 rounded-sm dark:bg-blue-200 dark:text-blue-800 inline-block">介绍</h2>
            <p>
                {baseData && basename}
                {baseData && dlcData && '与'}
                {dlcData && dlcname}中的
                {level === 1 ? (
                    <span style="color: #5bae23; text-shadow: 0 0 8px #5bae23, 0 0 12px #5bae23;">顶级专属个人特性</span>
                ) : level === 2 ? (
                    <span style="color: #5bae22">专属个人特性</span>
                ) : level === 3 ? (
                    <span style="color: #de1c31">负面个人特性</span>
                ) : (
                    <span style="color: #4a5568">个人特性</span>
                )}
                。
            </p>
        </>
    )
}
