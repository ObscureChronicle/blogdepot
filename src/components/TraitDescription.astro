---
type Props = {
    baseDescription: string;
    dlcDescription: string;
};

const { baseDescription, dlcDescription } = Astro.props as Props;
---

{
    (baseDescription && baseDescription.length > 0) || (dlcDescription && dlcDescription.length > 0) ? (
        <>
            <h2 class="bg-blue-100 text-blue-800 text-2xl font-bold px-2.5 pt-1.5 rounded-sm dark:bg-blue-200 dark:text-blue-800 inline-block">描述</h2>
            <div class="flex flex-col pl-4 gap-4">
                {baseDescription && baseDescription.length > 0 && (
                    <div class="flex flex-col items-start">
                        <span class="inline-block bg-blue-100 text-blue-800 text-base font-medium px-1.5 pt-1 rounded-sm dark:bg-blue-900 dark:text-blue-300">
                            本传
                        </span>
                        <p set:html={baseDescription} class="text-base leading-relaxed" />
                    </div>
                )}
                {dlcDescription && dlcDescription.length > 0 && (
                    <div class="flex flex-col items-start">
                        <span class="inline-block bg-yellow-100 text-yellow-800 text-base font-medium px-1.5 pt-1 rounded-sm dark:bg-yellow-900 dark:text-yellow-300">
                            星命诀
                        </span>
                        <p set:html={dlcDescription} class="text-base leading-relaxed" />
                    </div>
                )}
            </div>
        </>
    ) : null
}
