---
type Props = {
    description: string;
};

const { description } = Astro.props as Props;
---
{
    description && (
        <>
            <h2 class="bg-blue-100 text-blue-800 text-2xl font-bold px-2.5 pt-1.5 rounded-sm dark:bg-blue-200 dark:text-blue-800 inline-block">描述</h2>
            <p class="whitespace-pre-line text-base leading-relaxed">{description}</p>
        </>
    )
}