---
type Props = {
    noteHtml?: string;
};

const { noteHtml } = Astro.props as Props;
---

{
    noteHtml && noteHtml.length > 0 ? (
        <>
            <h2 class="bg-blue-100 text-blue-800 text-2xl font-bold px-2.5 pt-1.5 rounded-sm dark:bg-blue-200 dark:text-blue-800 inline-block">说明</h2>
            <div set:html={noteHtml} class="whitespace-pre-line text-base leading-relaxed"></div>
        </>
    ) : null
}
