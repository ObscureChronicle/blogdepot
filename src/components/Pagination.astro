---
import type { Page } from 'astro';
import ArrowLeft from '../icons/ArrowLeft.astro';
import ArrowRight from '../icons/ArrowRight.astro';
import IconButton from './IconButton.astro';
import { buildPageUrl, getPaginationRange } from '../utils/pagination-utils';

type Props = {
    page: Page<unknown>;
    basePath: string;
    siblingCount?: number;
    boundaryCount?: number;
    class?: string;
};

const { page, basePath, siblingCount = 1, boundaryCount = 1, class: className } = Astro.props;

const items = getPaginationRange(page.currentPage, page.lastPage, siblingCount, boundaryCount);
---

<nav
    aria-label="Pagination"
    data-pagination-nav
    data-prev-href={page.url.prev}
    data-next-href={page.url.next}
    class:list={['px-12 py-2 relative text-center', className]}
>
    {
        page.url.prev && (
            <IconButton
                class="absolute left-0 top-1/2 -translate-y-1/2"
                href={page.url.prev}
                data-astro-prefetch
                aria-label={`Go to page ${page.currentPage - 1} of ${page.lastPage}`}
            >
                <ArrowLeft class="w-5 h-5 fill-current" />
            </IconButton>
        )
    }
    <span class="text-sm sm:hidden">第 {page.currentPage} 页，共 {page.lastPage} 页</span>
    {
        page.lastPage > 1 && (
            <div class="pagination-jump mt-2 flex items-center justify-center gap-1 sm:hidden">
                <span class="text-sm">跳转到</span>
                <input
                    type="number"
                    inputmode="numeric"
                    step="1"
                    min="1"
                    max={page.lastPage}
                    class="pagination-jump-input h-8 w-12 rounded-full border border-main bg-main px-1 text-center text-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--border-main)]"
                    placeholder={String(page.currentPage)}
                    aria-label={`输入页码跳转，共 ${page.lastPage} 页`}
                    data-current-page={page.currentPage}
                    data-last-page={page.lastPage}
                    data-base-path={basePath}
                />
                <button
                    type="button"
                    class="pagination-jump-btn inline-flex h-8 items-center justify-center rounded-full border border-main px-2 text-sm transition hover:bg-muted focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--border-main)]"
                    aria-label="跳转到指定页码"
                >
                    Go
                </button>
            </div>
        )
    }
    {
        page.lastPage > 1 && (
            <ul class="hidden sm:inline-flex items-center gap-1 align-middle">
                {items.map((item) => (
                    <li>
                        {item === 'ellipsis' ? (
                            <span class="inline-flex h-8 min-w-8 items-center justify-center px-1 text-sm select-none" aria-hidden="true">
                                …
                            </span>
                        ) : (
                            <a
                                href={buildPageUrl(basePath, item)}
                                data-astro-prefetch
                                aria-label={`Go to page ${item} of ${page.lastPage}`}
                                aria-current={item === page.currentPage ? 'page' : undefined}
                                class:list={[
                                    'inline-flex h-8 min-w-8 items-center justify-center rounded-full px-2 text-sm transition focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--border-main)]',
                                    item === page.currentPage ? 'border border-main bg-muted' : 'hover:bg-muted'
                                ]}
                            >
                                {item}
                            </a>
                        )}
                    </li>
                ))}
                {
                    items.includes('ellipsis') && (
                        <li class="pagination-jump ml-2 inline-flex items-center gap-1">
                            <input
                                type="number"
                                inputmode="numeric"
                                step="1"
                                min="1"
                                max={page.lastPage}
                                class="pagination-jump-input h-8 w-12 rounded-full border border-main bg-main px-1 text-center text-sm focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--border-main)]"
                                placeholder={String(page.currentPage)}
                                aria-label={`输入页码跳转，共 ${page.lastPage} 页`}
                                data-current-page={page.currentPage}
                                data-last-page={page.lastPage}
                                data-base-path={basePath}
                            />
                            <button
                                type="button"
                                class="pagination-jump-btn inline-flex h-8 items-center justify-center rounded-full border border-main px-2 text-sm transition hover:bg-muted focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--border-main)]"
                                aria-label="跳转到指定页码"
                            >
                                Go
                            </button>
                        </li>
                    )
                }
            </ul>
        )
    }
    {
        page.url.next && (
            <IconButton
                class="absolute right-0 top-1/2 -translate-y-1/2"
                href={page.url.next}
                data-astro-prefetch
                aria-label={`Go to page ${page.currentPage + 1} of ${page.lastPage}`}
            >
                <ArrowRight class="w-5 h-5 fill-current" />
            </IconButton>
        )
    }
</nav>

<script>
    import { navigate } from 'astro:transitions/client';
    import { buildPageUrl, clampPage } from '../utils/pagination-utils';

    function initPaginationJump() {
        document.querySelectorAll<HTMLElement>('.pagination-jump').forEach((container) => {
            if (container.dataset.bound === 'true') return;
            container.dataset.bound = 'true';

            const input = container.querySelector<HTMLInputElement>('.pagination-jump-input');
            const button = container.querySelector<HTMLButtonElement>('.pagination-jump-btn');
            if (!input || !button) return;

            const currentPage = Number(input.dataset.currentPage);
            const lastPage = Number(input.dataset.lastPage);
            const basePath = input.dataset.basePath ?? '';

            const jump = () => {
                const raw = input.value.trim();
                const value = Number(raw);

                if (!raw || !Number.isInteger(value) || value < 1) {
                    input.classList.add('border-red-500');
                    return;
                }

                const target = clampPage(value, lastPage);
                if (target === currentPage) return;

                navigate(buildPageUrl(basePath, target));
            };

            input.addEventListener('input', () => input.classList.remove('border-red-500'));
            input.addEventListener('keydown', (event) => {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    jump();
                }
            });
            button.addEventListener('click', jump);
        });
    }

    // Registered once (module scope survives client-side transitions); looks up the
    // live nav on every keypress so it stays correct after astro:page-load swaps.
    let keyboardNavBound = false;

    function bindPaginationKeyboardNav() {
        if (keyboardNavBound) return;
        keyboardNavBound = true;

        document.addEventListener('keydown', (event) => {
            if (event.defaultPrevented || event.altKey || event.ctrlKey || event.metaKey || event.shiftKey) return;
            if (event.key !== 'ArrowLeft' && event.key !== 'ArrowRight') return;

            const target = event.target as HTMLElement | null;
            if (target && (['INPUT', 'TEXTAREA', 'SELECT'].includes(target.tagName) || target.isContentEditable)) return;

            const nav = document.querySelector<HTMLElement>('[data-pagination-nav]');
            if (!nav) return;

            const href = event.key === 'ArrowLeft' ? nav.dataset.prevHref : nav.dataset.nextHref;
            if (href) navigate(href);
        });
    }

    function init() {
        initPaginationJump();
        bindPaginationKeyboardNav();
    }

    init();
    document.addEventListener('astro:page-load', init);
</script>
